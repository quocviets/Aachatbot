# ─── App ───────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_VERSION=1.0.0

# ─── Storage ───────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ─── Database ──────────────────────────────────────────────────────
# SQLite (demo):
DATABASE_URL=sqlite+aiosqlite:///./plant_disease.db
# PostgreSQL (production — uncomment khi cần):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/plant_disease

# ─── AI Model ──────────────────────────────────────────────────────
# Để trống = tự scan từ ../Model/
MODEL_DIR=

# ─── CORS ──────────────────────────────────────────────────────────
# Dấu phẩy phân cách; dùng * cho dev
ALLOWED_ORIGINS=*

# ─── Rate Limit ────────────────────────────────────────────────────
RATE_LIMIT=20/minute
