# App Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_VERSION=1.0.0

# Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Database
DATABASE_URL=sqlite+aiosqlite:///./plant_disease.db

# AI Model
MODEL_DIR=Model

# CORS
ALLOWED_ORIGINS=*

# Rate Limit (requests per minute)
RATE_LIMIT=20/minute